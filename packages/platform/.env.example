# AVP Platform API — local development defaults
# Copy to .env and override as needed. Do not commit secrets.

PORT=7070

# --- Postgres (required) ---
# Local Windows / macOS Postgres (recommended without Docker):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=avp
DB_USER=avp
DB_PASSWORD=avp_dev_password
# Create role+db once:  .\deploy\local-postgres\setup.ps1
# (or: psql -U postgres -f deploy/local-postgres/init-avp.sql then CREATE DATABASE avp OWNER avp;)

# Docker Compose defaults (Postgres published on host 5433):
# DB_HOST=localhost
# DB_PORT=5433
# DB_NAME=avp
# DB_USER=avp
# DB_PASSWORD=avp_dev_password

# Neon / Supabase (cloud):
# DB_HOST=ep-xxxx.region.aws.neon.tech
# DB_PORT=5432
# DB_NAME=neondb
# DB_USER=neondb_owner
# DB_PASSWORD=xxxxxxxx
# DB_SSL=require

# --- Redis (optional for Studio demo) ---
# If Redis is down, Platform uses in-memory working memory automatically.
REDIS_HOST=localhost
REDIS_PORT=6379
# Set REDIS_OPTIONAL=0 to require Redis and fail startup if missing.

NATS_URL=nats://localhost:4222
STUDIO_SECRET=avp-studio-dev-secret
# KEY_DIR=~/.avp/keys
# ANTHROPIC_API_KEY=
