{
  "name": "@avp/platform",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./llm/llmGateway.js": {
      "types": "./dist/llm/llmGateway.d.ts",
      "import": "./dist/llm/llmGateway.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && cp src/db/schema.sql dist/db/schema.sql",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@avp/shared": "workspace:*",
    "@fastify/cors": "^9.0.0",
