    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.52.1",
    "@opentelemetry/exporter-prometheus": "^0.53.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.53.0",
    "@opentelemetry/sdk-metrics": "^1.26.0",
    "@opentelemetry/sdk-node": "^0.53.0",
    "@opentelemetry/sdk-trace-node": "^1.26.0",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^7.0.1",
    "dotenv": "^16.4.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.0",
    "jose": "^5.6.0",
    "nats": "^2.28.0",
    "pg": "^8.12.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@avp/agents-build-documentation": "workspace:^",
    "@avp/agents-build-quality-engineering": "workspace:^",
    "@avp/agents-build-software-engineering": "workspace:^",
